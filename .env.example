# Database
DATABASE_URL="postgresql://hermes:hermes_password@localhost:5435/hermes_kanban"

# BetterAuth
BETTER_AUTH_SECRET="your-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Hermes Agent Gateway
# Use "http://hermes:8642" when running Next.js in Docker too
# Use "http://127.0.0.1:8642" when running Next.js locally + Hermes in Docker
HERMES_GATEWAY_URL="http://127.0.0.1:8642"
HERMES_API_KEY="change-me-local-dev"
HERMES_HOME=""
HERMES_WEBHOOK_SECRET=""

# LLM Provider: opencode-go (default, uses GLM models)
# Get your key at: https://open.bigmodel.cn or from your opencode-go setup
OPENCODE_GO_API_KEY=""
LLM_MODEL="glm-5.1"
LLM_PROVIDER="opencode-go"

# Alternative providers (uncomment to use instead):
# OPENROUTER_API_KEY=""           # OpenRouter (one key, many models)
# ANTHROPIC_API_KEY=""             # Anthropic directly
# OPENAI_API_KEY=""                # OpenAI directly
# CUSTOM_LLM_BASE_URL=""          # Custom OpenAI-compatible endpoint
# CUSTOM_LLM_API_KEY=""           #    (Ollama, vLLM, Zhipu, etc.)

# Optional: Resend for emails
RESEND_API_KEY="your-resend-api-key"

# Optional: Supabase (for Realtime features)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"