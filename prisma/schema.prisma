// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BETTER AUTH MODELS
// ============================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  emailVerified  Boolean  @default(false)
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // BetterAuth relations
  sessions  Session[]
  accounts  Account[]

  // App relations
  ownedOrganizations Organization[]      @relation("OrganizationOwner")
  memberships        OrganizationMember[]
  createdProjects    Project[]           @relation("ProjectCreator")
  blockedTasks       Task[]              @relation("TaskBlockedBy")
  taskComments       TaskComment[]
  notifications      Notification[]

  @@map("users")
}

model Session {
  id           String   @id
  userId       String
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  token        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String   @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

// ============================================
// ORGANIZATIONS
// ============================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  objective   String?
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner       User?               @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members     OrganizationMember[]
  projects    Project[]
  tasks       Task[]
  agents      Agent[]
  templates   AgentTemplate[]
  mcpServers  McpServer[]
  notifications Notification[]

  @@map("organizations")
}

model OrganizationMember {
  id              String   @id @default(cuid())
  orgId           String
  userId          String
  role            String   @default("member") // owner, board, member
  responsibilities String[]
  domains         String[]
  joinedAt        DateTime @default(now())

  // Relations
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("organization_members")
}

// ============================================
// INVITATIONS
// ============================================

model Invitation {
  id          String    @id @default(cuid())
  orgId       String
  email       String
  role        String    @default("board")
  invitedBy   String?
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("invitations")
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  status      String   @default("active") // active, paused, completed, archived
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      User?        @relation("ProjectCreator", fields: [createdBy], references: [id])
  tasks        Task[]

  @@map("projects")
}

// ============================================
// TASKS (Mirror de Hermes Kanban)
// ============================================

model Task {
  id                String    @id @default(cuid())
  hermesTaskId      String?   @unique
  projectId         String
  orgId             String
  title             String
  body              String?
  status            String    @default("triage") // triage, todo, ready, running, blocked, done, archived
  priority          Int       @default(0)
  assignee          String?   // Profile name del agente
  tenant            String?
  workspaceType     String    @default("scratch") // scratch, worktree, dir
  workspacePath     String?
  blockedReason     String?
  blockedBy         String?
  approvalRequired  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  hermesMetadata    Json?     @default("{}")

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [orgId], references: [id])
  blocker      User?         @relation("TaskBlockedBy", fields: [blockedBy], references: [id])
  parentLinks  TaskLink[]    @relation("ParentTask")
  childLinks   TaskLink[]    @relation("ChildTask")
  comments     TaskComment[]
  notifications Notification[]

  @@map("tasks")
}

model TaskLink {
  id            String   @id @default(cuid())
  parentTaskId  String
  childTaskId   String
  createdAt     DateTime @default(now())

  // Relations
  parentTask Task @relation("ParentTask", fields: [parentTaskId], references: [id], onDelete: Cascade)
  childTask  Task @relation("ChildTask", fields: [childTaskId], references: [id], onDelete: Cascade)

  @@unique([parentTaskId, childTaskId])
  @@map("task_links")
}

model TaskComment {
  id          String   @id @default(cuid())
  taskId      String
  authorType  String   // user, agent
  authorId    String   // user_id o profile_name
  body        String
  createdAt   DateTime @default(now())

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [authorId], references: [id])

  @@map("task_comments")
}

// ============================================
// AGENT TEMPLATES
// ============================================

model AgentTemplate {
  id               String   @id @default(cuid())
  orgId            String?
  name             String
  displayName      String?
  description      String?
  roleType         String   @default("worker") // ceo, orchestrator, worker
  soulContent      String?
  defaultSkills    String[]
  defaultTools     String[]
  defaultToolsets  String[]
  modelOverride    String?
  createdBy        String?
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())

  // Relations
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agents       Agent[]

  @@map("agent_templates")
}

// ============================================
// AGENT INSTANCES
// ============================================

model Agent {
  id                String   @id @default(cuid())
  orgId             String
  templateId        String?
  hermesProfile     String   @unique
  name              String
  description       String?
  soulContent       String?
  skills            String[]
  tools             String[]
  toolsets          String[]
  mcpServers        Json     @default("[]")
  webhooks          Json     @default("[]")
  apiIntegrations   Json     @default("[]")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  // Relations
  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template     AgentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("agents")
}

// ============================================
// MCP SERVER CONFIGS
// ============================================

model McpServer {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  transport    String   @default("stdio") // stdio, http
  command      String?
  url          String?
  envVars      Json     @default("{}")
  toolsFilter  String[]
  createdAt    DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("mcp_servers")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id         String    @id @default(cuid())
  userId     String
  orgId      String?
  type       String
  taskId     String?
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task         Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// WEBHOOK EVENTS
// ============================================

model WebhookEvent {
  id         String   @id @default(cuid())
  orgId      String?
  webhookId  String?
  eventType  String
  payload    Json
  status     String   @default("pending") // pending, delivered, failed
  attempts   Int      @default(0)
  deliveredAt DateTime?
  createdAt  DateTime @default(now())

  @@map("webhook_events")
}
